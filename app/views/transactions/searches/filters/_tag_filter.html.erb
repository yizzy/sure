<%# locals: (form:) %>
<div data-controller="list-filter">
  <%= render DS::SearchInput.new(
        variant: :embedded,
        placeholder: t(".filter_tags"),
        aria_label: t(".filter_tags"),
        data: {
          list_filter_target: "input",
          action: "input->list-filter#filter"
        }
      ) %>
  <div class="my-2" id="list" data-list-filter-target="list">
    <% Current.family.tags.alphabetically.each do |tag| %>
      <div class="filterable-item flex items-center gap-2 p-2" data-filter-name="<%= tag.name %>">
        <%= form.check_box :tags,
                           {
                             multiple: true,
                             checked: @q[:tags]&.include?(tag.name),
                             class: "checkbox checkbox--light"
                           },
                           tag.name,
                           nil %>
        <%= form.label :tags, value: tag.name, class: "text-sm text-primary flex items-center gap-2" do %>
          <% tag_color = tag.color.presence || Tag::UNCATEGORIZED_COLOR %>
          <span class="border text-sm font-medium px-3 py-1 rounded-full inline-flex items-center gap-2"
                style="
                  background-color: color-mix(in oklab, <%= tag_color %> 10%, transparent);
                  border-color: color-mix(in oklab, <%= tag_color %> 20%, transparent);
                  color: <%= tag_color %>;">
                <span class="size-1.5 rounded-full" style="background-color: <%= tag_color %>;"></span>
            <%= tag.name %>
          </span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
